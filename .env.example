# .env.example — Copy this to .env and fill in your values
# This file IS committed to git (no real secrets here)

DB_HOST=localhost
DB_PORT=5432
DB_NAME=rss_pipeline
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
SCHEDULER_INTERVAL_MINUTES=60
LOG_LEVEL=INFO

# Vector Embedding Deduplication
# Cosine similarity threshold (0.0–1.0). Articles above this are treated as
# semantic duplicates and skipped. Higher = stricter. Default: 0.92.
VECTOR_SIM_THRESHOLD=0.92
# Embedding model (384-dim, ~80 MB, downloads once automatically).
VECTOR_MODEL_NAME=all-MiniLM-L6-v2
